generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  startDate       DateTime  @default(now())
  endDate         DateTime?
  cost            Int?
  motif           String?
  transactionDate DateTime?
  transactionId   String?
  findings        String?
  doctorId        String?
  id              String    @id @unique @default(cuid())
  patientId       String?
  status          Status?   @default(offline)
  head            Float?
  height          Float?
  weight          Float?
  exams           Json?
  medication      Json?
  arm             Float?
  sao2            Float?
  temperature     Float?
  vectorId        Int?
  Doctor          Doctor?   @relation(fields: [doctorId], references: [id])
  Patient         Patient?  @relation(fields: [patientId], references: [id])
}

model Doctor {
  cost         Int?
  duration     Int?
  phone        String?
  experience   Int?
  isActive     Boolean       @default(false)
  isCompleted  Boolean       @default(false)
  isDoctor     Boolean       @default(false)
  isMedPro     Boolean       @default(false)
  spec         String?
  summary      String?
  title        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now())
  availability Json?
  id           String        @id @unique @default(cuid())
  email        String
  firstname    String
  lastname     String
  appointments Appointment[]
  Img          Img?
  patients     Patient[]
}

model Img {
  url       String
  public_id String
  doctorId  String? @unique
  id        String  @id @unique
  Doctor    Doctor? @relation(fields: [doctorId], references: [id])
}

model Patient {
  firstname    String
  lastname     String
  email        String?
  isCompleted  Boolean       @default(false)
  phone        String?
  profession   String?
  religion     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now())
  id           String        @id @unique @default(cuid())
  doctorId     String?
  birthdate    DateTime
  mothername   String?
  sex          Sex?
  children     Int?
  allergies    String?
  history      String?
  bloodtype    String?
  vectorId     Int?
  appointments Appointment[]
  Doctor       Doctor?       @relation(fields: [doctorId], references: [id])
}

model documents {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

enum Sex {
  male
  female
}

enum Status {
  pending
  paid
  offline
}
