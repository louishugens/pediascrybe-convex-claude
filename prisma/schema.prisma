generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  startDate       DateTime  @default(now())
  endDate         DateTime?
  cost            Int?
  motif           String?
  transactionDate DateTime?
  transactionId   String?
  findings        String?
  recommendation  String?
  doctorId        String?
  id              String    @id @unique @default(cuid())
  patientId       String?
  status          Status?   @default(offline)
  head            Float?
  height          Float?
  weight          Float?
  exams           Json?
  medication      Json?
  arm             Float?
  sao2            Float?
  temperature     Float?
  pulse           Int?
  respiratory     Int?
  systolic        Float?
  diastolic       Float?
  vectorId        Int?
  files           String[]
  Doctor          Doctor?   @relation(fields: [doctorId], references: [id])
  Patient         Patient?  @relation(fields: [patientId], references: [id])
  uploadedFiles   File[]
}

model Doctor {
  cost         Int?
  duration     Int?
  phone        String?
  address      String?
  experience   Int?
  isActive     Boolean       @default(false)
  isCompleted  Boolean       @default(false)
  isDoctor     Boolean       @default(false)
  isMedPro     Boolean       @default(false)
  spec         String?
  summary      String?
  title        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now())
  availability Json?
  id           String        @id @unique @default(cuid())
  email        String
  firstname    String
  lastname     String
  appointments Appointment[]
  Img          Img?
  patients     Patient[]
}

model Img {
  url       String
  public_id String
  doctorId  String? @unique
  id        String  @id @unique
  Doctor    Doctor? @relation(fields: [doctorId], references: [id])
}

model Patient {
  firstname    String
  lastname     String
  email        String?
  isCompleted  Boolean       @default(false)
  phone        String?
  profession   String?
  religion     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now())
  id           String        @id @unique @default(cuid())
  doctorId     String?
  birthdate    DateTime
  mothername   String?
  sex          Sex?
  children     Int?
  allergies    String?
  history      String?
  bloodtype    String?
  vectorId     Int?
  appointments Appointment[]
  Doctor       Doctor?       @relation(fields: [doctorId], references: [id])
  reports      Report[]
}

model documents {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

enum Sex {
  male
  female
}

enum Status {
  pending
  paid
  offline
}

model File {
  id            String      @id @unique @default(cuid())
  url           String      @unique
  name          String
  fileType      FileType
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  appointmentId String
}

enum FileType {
  IMAGE
  PDF
}

model Report {
  id         String     @id @unique @default(cuid())
  createdAt  DateTime   @default(now())
  reportType ReportType
  content    String
  Patient    Patient?   @relation(fields: [patientId], references: [id])
  patientId  String?
}

enum ReportType {
  Report
  Certificate
}
