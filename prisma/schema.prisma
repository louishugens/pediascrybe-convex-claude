generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Appointment {
  startDate       DateTime  @default(now())
  endDate         DateTime?
  cost            Int?
  motif           String?
  transactionDate DateTime?
  transactionId   String?
  findings        String?
  recommendation  String?
  doctorId        String?
  id              String    @id @unique @default(cuid())
  patientId       String?
  status          Status?   @default(offline)
  head            Float?
  height          Float?
  weight          Float?
  exams           Json?
  medication      Json?
  arm             Float?
  sao2            Float?
  temperature     Float?
  pulse           Int?
  respiratory     Int?
  systolic        Float?
  diastolic       Float?
  vectorId        Int?
  files           String[]
  Doctor          Doctor?   @relation(fields: [doctorId], references: [id])
  Patient         Patient?  @relation(fields: [patientId], references: [id])
  uploadedFiles   File[]
}

model Doctor {
  cost         Int?
  duration     Int?
  phone        String?
  address      String?
  experience   Int?
  isActive     Boolean        @default(false)
  isCompleted  Boolean        @default(false)
  isDoctor     Boolean        @default(false)
  isMedPro     Boolean        @default(false)
  spec         String?
  summary      String?
  title        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @default(now())
  availability Json?
  id           String         @id @unique @default(cuid())
  email        String
  firstname    String
  lastname     String
  appointments Appointment[]
  Img          Img?
  patients     Patient[]
  Subscription Subscription[]
  trackedVaccines Vaccin[]
}

model Img {
  url       String
  public_id String
  doctorId  String? @unique
  id        String  @id @unique
  Doctor    Doctor? @relation(fields: [doctorId], references: [id])
}

model Patient {
  firstname         String
  lastname          String
  email             String?
  isCompleted       Boolean             @default(false)
  phone             String?
  profession        String?
  religion          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now())
  id                String              @id @unique @default(cuid())
  doctorId          String?
  birthdate         DateTime
  mothername        String?
  sex               Sex?
  children          Int?
  allergies         String?
  history           String?
  bloodtype         String?
  electrophoresis   String?
  vectorId          Int?
  appointments      Appointment[]
  Doctor            Doctor?             @relation(fields: [doctorId], references: [id])
  reports           Report[]
  receipts          Receipt[]
  VaccinationRecords VaccinationRecord[]
}

model documents {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

enum Sex {
  male
  female
}

enum Status {
  pending
  paid
  offline
}

model File {
  id            String      @id @unique @default(cuid())
  url           String      @unique
  name          String
  fileType      FileType
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  appointmentId String
}

enum FileType {
  IMAGE
  PDF
}

model Report {
  id         String     @id @unique @default(cuid())
  createdAt  DateTime   @default(now())
  reportType ReportType
  content    String
  Patient    Patient?   @relation(fields: [patientId], references: [id])
  patientId  String?
}

enum ReportType {
  Report
  Certificate
  ReferenceNote
}

model Receipt {
  id        String    @id @unique @default(cuid())
  createdAt DateTime  @default(now())
  services  Json?
  cost      Float?
  date      DateTime?
  currency  String?
  Patient   Patient?  @relation(fields: [patientId], references: [id])
  patientId String?
}

// ///////////////Stripe Payment////////////////////////

model Product {
  id          String   @id
  active      Boolean?
  name        String?
  description String?
  image       String?
  metadata    Json?
  price       Price[]
}

model Price {
  id                String                 @id
  active            Boolean?
  description       String?
  unit_amount       Int?
  product           Product                @relation(fields: [productId], references: [id])
  currency          String?
  pricing_type      Pricing_type?
  interval          Pricing_plan_interval?
  interval_count    Int?
  trial_period_days Int?
  metadata          Json?
  productId         String
  subscription      Subscription[]
}

enum Pricing_plan_interval {
  day
  week
  month
  year
}

enum Pricing_type {
  one_time
  recurring
}

model Subscription {
  id                   String              @id
  status               Subscription_status
  metadata             Json?
  price                Price               @relation(fields: [priceId], references: [id])
  quantity             Int?
  cancel_at_period_end Boolean?
  created              DateTime            @default(now())
  current_period_start DateTime            @default(now())
  current_period_end   DateTime            @default(now())
  ended_at             DateTime?           @default(now())
  cancel_at            DateTime?           @default(now())
  canceled_at          DateTime?           @default(now())
  trial_start          DateTime?           @default(now())
  trial_end            DateTime?           @default(now())
  doctor               Doctor?             @relation(fields: [doctorId], references: [id])
  doctorId             String?
  priceId              String
}

enum Subscription_status {
  trialing
  active
  canceled
  incomplete
  incomplete_expired
  past_due
  unpaid
  paused
}

model charts {
  id     String @id @unique
  p03    Json
  p15    Json
  p50    Json
  p85    Json
  p97    Json
  height Json?
}

model Vaccin {
  id                 String              @id @unique @default(cuid())
  name               String
  doses              Dose[]
  records            VaccinationRecord[]
  doctorId           String?
  doctor             Doctor?             @relation(fields: [doctorId], references: [id])
}

model VaccinationRecord {
  id           String   @id @unique @default(cuid())
  date         DateTime
  notes        String?
  patient      Patient  @relation(fields: [patientId], references: [id])
  patientId    String
  vaccin       Vaccin   @relation(fields: [vaccinId], references: [id])
  vaccinId     String
  manufacturer String
  lotNumber    String
  dose         Dose     @relation(fields: [doseId], references: [id])
  doseId       String
  @@unique([patientId, vaccinId, doseId])
}

model Dose {
  id                String              @id @unique @default(cuid())
  doseCount         Int?
  maxAge            Int?
  doseType          DoseType
  Vaccin            Vaccin?             @relation(fields: [vaccinId], references: [id], onDelete: Cascade)
  vaccinId          String?
  VaccinationRecord VaccinationRecord[]
}

model VaccinReference {
  id    String                @id @unique @default(cuid())
  name  String
  doses VaccinReferenceDose[]
}

model VaccinReferenceDose {
  id                String          @id @unique @default(cuid())
  doseCount         Int?
  maxAge            Int?
  doseType          DoseType
  vaccinReferenceId String
  vaccinReference   VaccinReference @relation(fields: [vaccinReferenceId], references: [id])
}

enum VaccineManufacturer {
  Pfizer
  Moderna
  JohnsonAndJohnson
  AstraZeneca
  Sanofi
  GlaxoSmithKline
  Merck
  Novavax
  Sinovac
  Sinopharm
  BharatBiotech
  SerumInstituteOfIndia
}

enum DoseType {
  regular
  annual
  booster
  unique
}

